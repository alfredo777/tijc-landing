<section class="bg-gray-900 py-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="text-center mb-10">
            <p class="text-amarillo font-bold uppercase tracking-widest text-sm mb-2">Revive la Emoción</p>
            <h2 class="font-display text-4xl font-bold text-white">{{video.titulo}}</h2>
        </div>
        
        <div class="relative aspect-video bg-gray-800 shadow-2xl">
            <iframe 
                class="w-full h-full"
                src="https://www.youtube.com/embed/GUNdmYq0OTM?si=KcFSLItg0UiKudkr" 
                title="{{video.titulo}}"
                frameborder="0" 
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
                allowfullscreen>
            </iframe>
        </div>
    </div>
</section>
