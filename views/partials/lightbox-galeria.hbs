<div id="galleryLightbox" class="lightbox-overlay" onclick="closeGalleryLightbox()">
    <div class="relative max-w-5xl w-full mx-4" onclick="event.stopPropagation()">
        <button class="absolute -top-12 right-0 text-white text-3xl hover:text-dorado transition-colors z-10" onclick="closeGalleryLightbox()">
            <i class="fas fa-times"></i>
        </button>
        
        <button class="absolute left-2 sm:-left-16 top-1/2 -translate-y-1/2 text-white text-4xl hover:text-dorado transition-colors z-10 bg-black/50 sm:bg-transparent p-2 sm:p-0 rounded" onclick="changeGalleryImage(-1)">
            <i class="fas fa-chevron-left"></i>
        </button>
        
        <div class="bg-black flex items-center justify-center min-h-[300px] sm:min-h-[500px]">
            <img id="galleryLightboxImg" src="" alt="Galería" class="max-w-full max-h-[80vh] object-contain">
        </div>
        
        <button class="absolute right-2 sm:-right-16 top-1/2 -translate-y-1/2 text-white text-4xl hover:text-dorado transition-colors z-10 bg-black/50 sm:bg-transparent p-2 sm:p-0 rounded" onclick="changeGalleryImage(1)">
            <i class="fas fa-chevron-right"></i>
        </button>
        
        <div class="text-center text-white mt-4">
            <span id="galleryCounter" class="bg-rosa px-4 py-2 text-sm font-semibold">1 / 30</span>
        </div>

        <div class="mt-4 overflow-x-auto">
            <div class="flex gap-2 justify-start sm:justify-center pb-2" id="galleryThumbnails"></div>
        </div>
    </div>
</div>