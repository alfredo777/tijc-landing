<section class="relative bg-white text-gray-900 py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        
        <div class="text-center mb-12">
            <p class="text-rosa font-bold uppercase tracking-widest text-sm mb-2">Fecha del Torneo</p>
            <h2 class="font-display text-5xl sm:text-6xl font-bold text-rosa">
                {{torneo.fechaInicio}} - {{torneo.fechaFin}} <span class="text-dorado-dark">{{torneo.mes}}</span>
            </h2>
        </div>

        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-3xl mx-auto">
            <div class="bg-rosa text-white p-6 text-center">
                <span id="days" class="font-display text-5xl font-bold block">00</span>
                <span class="text-sm uppercase tracking-wider opacity-80">Días</span>
            </div>
            <div class="bg-rosa text-white p-6 text-center">
                <span id="hours" class="font-display text-5xl font-bold block">00</span>
                <span class="text-sm uppercase tracking-wider opacity-80">Horas</span>
            </div>
            <div class="bg-rosa text-white p-6 text-center">
                <span id="minutes" class="font-display text-5xl font-bold block">00</span>
                <span class="text-sm uppercase tracking-wider opacity-80">Minutos</span>
            </div>
            <div class="bg-rosa text-white p-6 text-center">
                <span id="seconds" class="font-display text-5xl font-bold block">00</span>
                <span class="text-sm uppercase tracking-wider opacity-80">Segundos</span>
            </div>
        </div>
    </div>
</section>