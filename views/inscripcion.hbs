    <!-- JavaScript del formulario -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.getElementById('inscripcionForm');
            const successMessage = document.getElementById('successMessage');
            
            // Manejar selección de categoría visual
            const categoriaOptions = document.querySelectorAll('.categoria-option');
            categoriaOptions.forEach(option => {
                const radio = option.querySelector('input[type="radio"]');
                radio.addEventListener('change', function() {
                    categoriaOptions.forEach(opt => {
                        opt.classList.remove('border-rosa', 'border-dorado-dark', 'bg-rosa/5', 'bg-dorado/5');
                        opt.classList.add('border-gray-200');
                    });
                    if (this.checked) {
                        const cat = option.dataset.categoria;
                        option.classList.remove('border-gray-200');
                        if (cat === 'femenil') {
                            option.classList.add('border-rosa', 'bg-rosa/5');
                        } else {
                            option.classList.add('border-dorado-dark', 'bg-dorado/5');
                        }
                    }
                });
            });
            
            // Envío del formulario
            form.addEventListener('submit', async function(e) {
                e.preventDefault();
                
                const submitBtn = form.querySelector('button[type="submit"]');
                const originalText = submitBtn.innerHTML;
                
                // Estado de carga
                submitBtn.disabled = true;
                submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Enviando...';
                
                try {
                    const formData = new FormData(form);
                    const data = Object.fromEntries(formData.entries());
                    
                    const response = await fetch('/api/inscripcion', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify(data)
                    });
                    
                    const result = await response.json();
                    
                    if (result.success) {
                        form.style.display = 'none';
                        successMessage.classList.remove('hidden');
                        successMessage.scrollIntoView({ behavior: 'smooth', block: 'center' });
                    } else {
                        throw new Error(result.message || 'Error al enviar');
                    }
                } catch (error) {
                    alert('Hubo un error al enviar tu inscripción. Por favor intenta de nuevo.');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalText;
                }
            });
        });
    </script>
</body>
</html>
